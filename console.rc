IDD_DLG_QUERY DIALOGEX 0, 0, 186, 90
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | 
    WS_SYSMENU
CAPTION "Dialog"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,129,5,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,129,24,50,14
    EDITTEXT        IDC_QUERY_EDIT,15,52,155,15,ES_AUTOHSCROLL
    LTEXT           "Destination:",IDC_QUERY_TEXT,15,23,110,15
END

IDD_PROG DIALOGEX 0, 0, 186, 90
STYLE DS_SETFONT | DS_3DLOOK | DS_FIXEDSYS | DS_CENTER | WS_MINIMIZEBOX | 
    WS_MAXIMIZEBOX | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Dialog"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,129,7,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,129,24,50,14
    CONTROL         "",IDC_PROGRESS1,"msctls_progress32",WS_BORDER,7,52,172,
                    19
    LTEXT           "Static",IDC_LINE1,7,7,121,8
    LTEXT           "Static",IDC_LINE2,7,15,121,8
    LTEXT           "Static",IDC_LINE3,7,24,121,8
    LTEXT           "Static",IDC_LINE4,7,32,121,8
END

IDD_MAIN DIALOGEX 0, 0, 186, 90
STYLE DS_SETFONT | DS_3DLOOK | DS_FIXEDSYS | DS_CENTER | WS_MINIMIZEBOX | 
    WS_MAXIMIZEBOX | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Dialog"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "Exit",IDC_EXIT,129,69,50,14
    CONTROL         "",IDC_FRAME,"Static",SS_BITMAP,160,66,15,13
END

IDD_VIDSTREAMDLG DIALOG  0, 0, 120, 109
STYLE DS_SETFONT | DS_MODALFRAME | DS_SETFOREGROUND | DS_3DLOOK | DS_CENTER | 
    WS_MINIMIZEBOX | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "VidStream Client"
FONT 8, "MS Sans Serif"
BEGIN
    CHECKBOX        "Connect...",IDC_CONNECT,4,88,52,16,BS_PUSHLIKE
    CONTROL         "Overlay Connection Details",IDC_OVERLAY,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,8,76,101,10
    PUSHBUTTON      "Copy",IDC_COPY,64,88,52,16
    CONTROL         "",IDC_FRAME,"Static",SS_BLACKFRAME | SS_SUNKEN,8,4,104,
                    68
END


