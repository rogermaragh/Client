/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MENU1 MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                       ID_FILE_EXIT
    END
END

IDR_MENU_POPUPS MENU 
BEGIN
    POPUP "File Explorer"
    BEGIN
        MENUITEM "Refresh",                     ID_FILEEXPLORER_REFRESH
        MENUITEM SEPARATOR
        MENUITEM "Delete...",                   ID_FILEEXPLORER_DELETE
        MENUITEM "Execute",                     ID_FILEEXPLORER_EXECUTE
        MENUITEM "Move...",                     ID_FILEEXPLORER_MOVE
        MENUITEM "Copy...",                     ID_FILEEXPLORER_COPY
        MENUITEM SEPARATOR
        MENUITEM "Download...",                 ID_FILEEXPLORER_DOWNLOAD
        MENUITEM "Upload...",                   ID_FILEEXPLORER_UPLOAD
        MENUITEM "Compare...",                  ID_FILEEXPLORER_COMPARE
        MENUITEM SEPARATOR
        MENUITEM "New Folder...",               ID_FILEEXPLORER_NEWFOLDER
    END
    POPUP "Window Explorer"
    BEGIN
        MENUITEM "Refresh",                     ID_WINDOWEXPLORER_REFRESH
        MENUITEM SEPARATOR
        POPUP "Visibility"
        BEGIN
            MENUITEM "Show",                        ID_WINDOWEXPLORER_SHOW
            MENUITEM "Hide",                        ID_WINDOWEXPLORER_HIDE
            MENUITEM SEPARATOR
            MENUITEM "Minimize",                    ID_WINDOWEXPLORER_MINIMIZE

            MENUITEM "Maximize",                    ID_WINDOWEXPLORER_MAXIMIZE

            MENUITEM "Restore",                     ID_WINDOWEXPLORER_RESTORE

        END
        MENUITEM "Enable",                      ID_WINDOWEXPLORER_ENABLE
        MENUITEM "Disable",                     ID_WINDOWEXPLORER_DISABLE
        MENUITEM SEPARATOR
        MENUITEM "Set Caption...",              ID_WINDOWEXPLORER_SETCAPTION
        MENUITEM "Bring to Front",              ID_WINDOWEXPLORER_BRINGTOFRONT

        MENUITEM "Close",                       ID_WINDOWEXPLORER_CLOSE
    END
    POPUP "Registry Explorer"
    BEGIN
        MENUITEM "Refresh",                     ID_REGISTRYEXPLORER_REFRESH
        POPUP "Root"
        BEGIN
            MENUITEM "HKEY_CLASSES_ROOT",           ID_ROOT_HKEY
            MENUITEM "HKEY_CURRENT_USER",           ID_ROOT_HKEY40033
            MENUITEM "HKEY_LOCAL_MACHINE",          ID_ROOT_HKEY40034
            MENUITEM "HKEY_USERS",                  ID_ROOT_HKEY40035
            MENUITEM "HKEY_CURRENT_CONFIG",         ID_ROOT_HKEY40036
        END
        MENUITEM SEPARATOR
        MENUITEM "Set Value...",                ID_REGISTRYEXPLORER_SETVALUE
        POPUP "Create"
        BEGIN
            MENUITEM "Sub Key",                     ID_CREATE_SUBKEY
            MENUITEM "String Value",                ID_CREATE_STRINGVALUE
            MENUITEM "Dword Value",                 ID_CREATE_DWORDVALUE
            MENUITEM "Binary Value",                ID_CREATE_BINARYVALUE
        END
        MENUITEM "Delete",                      ID_REGISTRYEXPLORER_DELETE
    END
END


